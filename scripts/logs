#!/usr/bin/env bash

set -euo pipefail

key_path="$HOME/Desktop/AWSGOOB.pem"
host='ubuntu@98.88.81.139'

command -v ssh >/dev/null 2>&1 || { printf 'Error: SSH is not available on PATH.\n' >&2; exit 1; }
[[ -f "$key_path" ]] || { printf 'Error: SSH key not found at %s\n' "$key_path" >&2; exit 1; }

printf 'Connecting to %s for container status and recent Watchtower logs...\n\n' "$host"
ssh -i "$key_path" "$host" '
  set -e
  printf "==> Running containers\n"
  docker ps
  printf "\n==> Last 30 Watchtower log lines\n"
  docker logs watchtower --tail 30
'
