#!/usr/bin/env bash

set -euo pipefail

fail() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
config_file="$script_dir/config.sh"

[[ -f "$config_file" ]] || fail "AWS configuration file not found at $config_file"
# shellcheck source=config.sh
source "$config_file"
[[ -n "${AWS_HOST:-}" ]] || fail 'AWS_HOST is empty in scripts/config.sh'

command -v ssh >/dev/null 2>&1 || fail 'SSH is not available on PATH.'
[[ -f "$AWS_KEY_PATH" ]] || fail "SSH key not found at $AWS_KEY_PATH"

printf 'Connecting to %s for read-only deployment status...\n\n' "$AWS_HOST"
ssh -i "$AWS_KEY_PATH" "$AWS_HOST" '
  set -e
  printf "==> Docker Compose services\n"
  docker compose ps
  printf "\n==> Docker images\n"
  docker image ls
  printf "\n==> Running containers\n"
  docker ps
'
