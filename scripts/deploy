#!/usr/bin/env bash

set -euo pipefail

info() {
  printf '\n==> %s\n' "$1"
}

fail() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

if [[ $# -lt 1 || -z "$1" ]]; then
  fail 'A commit message is required. Usage: npm run deploy -- "Your message"'
fi

commit_message=$1

git rev-parse --is-inside-work-tree >/dev/null 2>&1 \
  || fail 'This command must be run inside a Git repository.'

repository_root=$(git rev-parse --show-toplevel)
cd "$repository_root"

if [[ -z "$(git status --porcelain)" ]]; then
  fail 'There are no changes to deploy.'
fi

branch=$(git branch --show-current)
[[ -n "$branch" ]] || fail 'Cannot deploy from a detached HEAD. Check out a branch first.'

info 'Building the application'
if ! npm run build; then
  fail 'Build failed. Nothing was staged, committed, or pushed.'
fi

info 'Changes to be deployed'
git status --short

info 'Staging changes'
git add .

if git diff --cached --quiet; then
  fail 'There are no staged changes to commit after the build.'
fi

info "Committing to ${branch}"
git commit -m "$commit_message"

info "Pushing ${branch}"
git push origin "$branch"

printf '\nDeployment started successfully. GitHub Actions is running, and the AWS deployment has started.\n'
