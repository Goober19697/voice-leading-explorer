#!/usr/bin/env bash

set -euo pipefail

fail() {
  printf 'Error: %s\n' "$1" >&2
  exit 1
}

key_path="$HOME/Desktop/AWSGOOB.pem"
host='ubuntu@98.88.81.139'

command -v ssh >/dev/null 2>&1 || fail 'SSH is not installed or is not available on PATH.'
[[ -f "$key_path" ]] || fail "SSH key not found at $key_path"

printf 'Connecting to %s and following Watchtower logs.\n' "$host"
printf 'Press Control + C to exit log watching.\n\n'

exec ssh -i "$key_path" "$host" 'docker logs -f watchtower'
